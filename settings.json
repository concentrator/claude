{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(echo:*)",
      "Bash(jq:*)",
      "Bash(mkdir:*)",
      "Bash(chmod +x:*)",
      "Bash(bash -n:*)",
      "Bash(git:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "Bash(gh release:*)",
      "Bash(make:*)",
      "Bash(go:*)",
      "Bash(gofmt:*)",
      "Bash(goimports:*)",
      "Bash(golangci-lint:*)",
      "Bash(terraform:*)",
      "Bash(python3:*)",
      "Bash(curl:*)",
      "Bash(claude plugin:*)",
      "Skill(update-config)",
      "WebSearch",
      "WebFetch(domain:docs.wallarm.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:registry.terraform.io)",
      "WebFetch(domain:developer.hashicorp.com)",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)",
      "Edit(//tmp/**)",
      "Edit(//private/tmp/**)",
      "Write(//tmp/**)",
      "Write(//private/tmp/**)"
    ],
    "defaultMode": "default"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/dev-branch-guard.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/dev-secrets-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/dev-branch-guard.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/dev-secrets-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "jq -c '{ts: (now | strftime(\"%Y-%m-%dT%H:%M:%SZ\")), skill: .tool_input.skill}' >> ~/.claude/skill_invocations.jsonl 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "spinnerTipsEnabled": false,
  "effortLevel": "high",
  "editorMode": "normal",
  "preferredNotifChannel": "auto",
  "autoCompactEnabled": true,
  "switchModelsOnFlag": true,
  "remoteControlAtStartup": false
}
